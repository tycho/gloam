{#-
  gloam C generator — shared macros.
  Import with: {% import "utils.j2" as u with context %}
-#}

{#- Context struct type name, from the precomputed field on FeatureSet. -#}
{%- macro ctx_type() -%}{{ m.context_name }}{%- endmacro -%}

{#- "GloamGLContext *context" with an optional suffix (e.g. ", " for mid-param-list). -#}
{%- macro ctx_arg(suffix="") -%}
{{ ctx_type() }} *context{{ suffix }}
{%- endmacro -%}

{#-
  Open a platform-protection #if block for an extension's protect list.
  `protects` is a Vec<String> of platform macros, e.g. ["VK_USE_PLATFORM_WIN32_KHR"].
  Emits nothing when the list is empty.
-#}
{%- macro protect_begin(protects) -%}
{%- if protects | length > 0 -%}
#if {% for p in protects %}defined({{ p }}){% if not loop.last %} || {% endif %}{% endfor %}
{% endif -%}
{%- endmacro -%}

{%- macro protect_end(protects) -%}
{%- if protects | length > 0 -%}
#endif
{% endif -%}
{%- endmacro -%}

{#-
  Platform-protection #if block for a protection-coalesced group of
  types/enums/PFNs. Note the AND semantics, in contrast to the OR form
  above: an extension is enabled when ANY of its listed platform macros
  is defined, whereas a protection-grouped run was coalesced under the
  full macro set, so ALL of its macros must hold for the run to apply.
  Emits nothing when the list is empty.
-#}
{%- macro group_protect_begin(protects) -%}
{%- if protects | length > 0 -%}
#if defined({{ protects | join(") && defined(") }})
{% endif -%}
{%- endmacro -%}

{%- macro group_protect_end(protects) -%}
{%- if protects | length > 0 -%}
#endif
{% endif -%}
{%- endmacro -%}

{#-
  Extra load-function parameters specific to each spec, placed before
  the final GloamLoadFunc argument. For GL/Vulkan these are empty.
  Starts with a leading ", " when non-empty so it can sit directly after
  a preceding parameter without producing a double-comma.
-#}
{%- macro extra_load_params(spec) -%}
{%- if spec == "egl" %}, EGLDisplay display{%- endif -%}
{%- if spec == "glx" %}, Display *display, int screen{%- endif -%}
{%- if spec == "wgl" %}, HDC hdc{%- endif -%}
{%- endmacro -%}

{#- Matching arguments to forward on internal calls. -#}
{%- macro extra_load_args(spec) -%}
{%- if spec == "egl" %}, display{%- endif -%}
{%- if spec == "glx" %}, display, screen{%- endif -%}
{%- if spec == "wgl" %}, hdc{%- endif -%}
{%- endmacro -%}

{#-
  Loop that bulk-loads the pfnArray run of every enabled feature via the
  feature PFN range table. `loader_args` is the per-call-site argument
  list forwarded to gloam_load_pfn_range_* between the context and the
  range bounds (e.g. "getProcAddr" or "instance, device").
-#}
{%- macro load_feature_ranges(loader_args, comment) %}    /* {{ comment }} */
    for (i = 0; i < GLOAM_ARRAYSIZE(kFeatPfnRanges_{{ fs.spec_name | spec_display }}); ++i) {
        const GloamPfnRange_t *r = &kFeatPfnRanges_{{ fs.spec_name | spec_display }}[i];
        if (context->featArray[r->extension])
            gloam_load_pfn_range_{{ fs.spec_name }}(context, {{ loader_args }}, r->start, r->count);
    }
{%- endmacro -%}

{#- Same as load_feature_ranges, for the per-API extension range table. -#}
{%- macro load_extension_ranges(api, loader_args, comment="") -%}
{%- if comment %}    /* {{ comment }} */
{% endif %}    for (i = 0; i < GLOAM_ARRAYSIZE(kExtPfnRanges_{{ api }}); ++i) {
        const GloamPfnRange_t *r = &kExtPfnRanges_{{ api }}[i];
        if (context->extArray[r->extension])
            gloam_load_pfn_range_{{ fs.spec_name }}(context, {{ loader_args }}, r->start, r->count);
    }
{%- endmacro -%}

{#-
  Alias-resolution call, emitted only when --alias produced a pair table.
  Emits a surrounding blank line on each side (matching the historical
  inline form); emits nothing at all when aliasing is disabled.
-#}
{%- macro resolve_aliases() -%}
{%- if alias and fs.alias_pairs | length > 0 %}
    gloam_resolve_aliases_{{ fs.spec_name }}(context);
{% endif -%}
{%- endmacro -%}

{#-
  Emit a single system-header conflict guard: if the given macro is already
  defined, issue a hard error; otherwise define it to 1.
  Usage: {{ u.header_error("__gl_h_", "OpenGL (gl.h)", "gl") }}
-#}
{%- macro header_error(guard_macro, header_name, api) -%}
#ifdef {{ guard_macro }}
  #error {{ header_name }} header already included (API: {{ api }}), remove previous include!
#endif
#define {{ guard_macro }} 1
{%- endmacro -%}
